# ============================================================
# Acumatica connection — copy this file to .env and fill in
# ============================================================

# Full URL to your Acumatica instance (no trailing slash)
ACUMATICA_URL=http://localhost/AcumaticaERP

# The company / tenant name configured in Acumatica
ACUMATICA_COMPANY=MyCompanyName

# Acumatica login credentials
ACUMATICA_USERNAME=admin
ACUMATICA_PASSWORD=

# REST endpoint version (check Help > About in your Acumatica instance)
ACUMATICA_ENDPOINT_VER=20.200.001
ACUMATICA_ENDPOINT_NAME=Default
